{
  "name": "@animoca/credential-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Animoca credential management - automates schema creation, pricing, programs, and deployment",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "credential-mcp": "./bin/credential-mcp.js",
    "credential-mcp-http": "./bin/credential-mcp-http.js"
  },
  "scripts": {
    "build": "tsc && chmod +x bin/credential-mcp.js bin/credential-mcp-http.js",
    "run:server": "pnpm run build && node dist/httpServer.js",
    "watch": "tsc --watch",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "node --test tests/*.js",
    "test:ci": "npm run build && npm run test",
    "extract-zephyr": "node scripts/extract-zephyr-scenarios.js",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js",
    "signer": "npx -y serve static -p 3747",
    "signer:next": "cd signer-app && npm run build && npx -y serve out -p 3748"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "credentials",
    "verifiable-credentials",
    "animoca",
    "automation",
    "ai-assistant"
  ],
  "author": "Animoca",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@x402/core": "^2.6.0",
    "@x402/evm": "^2.6.0",
    "@x402/fetch": "^2.6.0",
    "axios": "^1.7.9",
    "axios-retry": "^4.5.0",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.3.1",
    "ethers": "^6.16.0",
    "express": "^4.21.0",
    "jose": "^5.9.6",
    "viem": "^2.21.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "eslint": "^9.15.0",
    "prettier": "^3.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.15.0",
    "xlsx": "^0.18.5"
  },
  "files": [
    "dist",
    "bin"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
