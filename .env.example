# Copy to .env and set values. Do not commit .env.

# API environment: sandbox | staging | production
CREDENTIAL_MCP_ENVIRONMENT=staging

# Optional: private key for on-chain tools (set price, payments, stake/unstake).
# Use a dedicated, low-value wallet. Never commit this file or .env.
# 64 hex chars, with or without 0x prefix.
# CREDENTIAL_MCP_PRIVATE_KEY=

# Alternative: seed phrase (BIP-39). Optional CREDENTIAL_MCP_ACCOUNT_INDEX (default 0).
# CREDENTIAL_MCP_SEED_PHRASE=
# CREDENTIAL_MCP_ACCOUNT_INDEX=0

# MOCA chain (auto-set from CREDENTIAL_MCP_ENVIRONMENT; override here if needed)
# MOCA_RPC_URL=
# MOCA_CHAIN_ID=
# MOCA_PAYMENTS_CONTRACT=
# MOCA_ISSUER_STAKING_CONTROLLER_ADDRESS=
