# Copy to .env and set values. Do not commit .env.
# Optional: run `node scripts/sync-env-from-dashboard.js [path-to-dashboard-env]` to auto-fill from credential-dashboard.

# ------------------------------------------------------------------------------
# Required
# ------------------------------------------------------------------------------

# API environment. Possible values: sandbox | sandbox-testnet | staging | production (or prod)
# - sandbox: credential-devnet API, devnet MOCA (chainId 5151). Reduced tool list; schema creation disabled until backend deployed.
# - sandbox-testnet: credential-testnet API (sandbox), testnet MOCA (chainId 222888). Aligns with credential-dashboard branch sandbox-testnet / .env.sandbox-testnet.
# - staging: credential staging API, devnet MOCA (chainId 5151)
# - production: credential production API, testnet MOCA (chainId 222888)
CREDENTIAL_MCP_ENVIRONMENT=staging

# API signature key (optional). Defaults to same value as Credential Dashboard (JAVA_API_AES_KEY in sig-header).
# Set only to override; e.g. if your dashboard uses a different key from API / Developer settings.
# CREDENTIAL_API_SIGNATURE_KEY=

# ------------------------------------------------------------------------------
# Optional – debugging
# ------------------------------------------------------------------------------

# Verbose API request/response logging. Possible values: 1 | true | (empty/omit)
# CREDENTIAL_MCP_DEBUG=

# ------------------------------------------------------------------------------
# Optional – on-chain tools (set price, payments, stake/unstake)
# ------------------------------------------------------------------------------

# Wallet private key (64 hex chars, with or without 0x). Use a dedicated, low-value wallet. Never commit.
# CREDENTIAL_MCP_PRIVATE_KEY=

# Alternative: BIP-39 seed phrase. Optional CREDENTIAL_MCP_ACCOUNT_INDEX (default 0).
# CREDENTIAL_MCP_SEED_PHRASE=
# CREDENTIAL_MCP_ACCOUNT_INDEX=0

# ------------------------------------------------------------------------------
# Optional – overrides (auto-set from CREDENTIAL_MCP_ENVIRONMENT if not set)
# ------------------------------------------------------------------------------

# Credential API base URL. Possible values (by env): https://credential-devnet.api.sandbox.air3.com | https://credential-testnet.api.sandbox.air3.com | https://credential.api.staging.air3.com | https://credential.api.air3.com
# CREDENTIAL_API_URL=

# Developer dashboard URL. Possible values: https://developers.sandbox.air3.com | https://developers.air3.com
# CREDENTIAL_DASHBOARD_URL=

# MOCA chain API. Possible values: https://api.staging.mocachain.org | https://api.mocachain.org
# MOCA_CHAIN_API_URL=

# MOCA RPC URL. Possible values: https://devnet-rpc.mocachain.org | https://testnet-rpc.mocachain.org
# MOCA_RPC_URL=

# MOCA chain ID. Possible values: 5151 (devnet) | 222888 (testnet)
# MOCA_CHAIN_ID=

# Payments controller contract. Possible values (devnet): 0x56ad210e36c8424d1d1cc5166b3f9fa4c03a8942 | (testnet): 0x8dE288d0fdfe3F165fCB305C7E0D812B05294C27
# MOCA_PAYMENTS_CONTRACT=

# Issuer staking controller. Possible values (devnet): 0x238e4AA1a6CF2A774079E73019402Beb03F3a7b5 | (testnet): 0xc625FcE7bfd12f024584e0f9f215F5E76c850d32
# MOCA_ISSUER_STAKING_CONTROLLER_ADDRESS=

# ------------------------------------------------------------------------------
# Optional – HTTP server & OAuth
# ------------------------------------------------------------------------------

# HTTP server port. Possible values: any number (default 3749)
# MCP_HTTP_PORT=3749

# Base URL of this MCP server (for OAuth redirects). Possible values: http://localhost:3749 | https://your-mcp-host.com
# MCP_OAUTH_BASE_URL=http://localhost:3749

# JWT secret for OAuth access tokens. Set a strong value in production.
# MCP_OAUTH_JWT_SECRET=

# Comma-separated OAuth redirect URIs (defaults include Cursor and VS Code callbacks).
# MCP_OAUTH_REDIRECT_URIS=

# Signer app URL (login / set-price). Default: https://credential-challenge-signer.netlify.app
# CREDENTIAL_SIGNER_URL=

# ------------------------------------------------------------------------------
# Optional – alias (same as CREDENTIAL_MCP_ENVIRONMENT)
# ------------------------------------------------------------------------------
# config_env=staging
