# Optional: enable on-chain tools (set price, payment deposit/withdraw/claim, stake/unstake MOCA).
# Set in MCP client env (e.g. Cursor MCP settings), not in this file. Never commit real keys.
#
# CREDENTIAL_MCP_PRIVATE_KEY=0x...
# or
# CREDENTIAL_MCP_SEED_PHRASE="twelve word mnemonic ..."
# CREDENTIAL_MCP_ACCOUNT_INDEX=0
#
# MOCA_RPC_URL=https://devnet-rpc.mocachain.org
# MOCA_CHAIN_ID=5151
# MOCA_PAYMENTS_CONTRACT=0x...
# MOCA_ISSUER_STAKING_CONTROLLER_ADDRESS=0x238e4AA1a6CF2A774079E73019402Beb03F3a7b5
# MOCA_GAS_LIMIT=800000
