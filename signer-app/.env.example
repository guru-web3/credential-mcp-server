# Get a free project ID at https://cloud.walletconnect.com/
# Required for WalletConnect (e.g. mobile wallet scan). Optional for injected wallets only.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# For /set-price page: MOCA chain and payments controller (staging testnet example).
# Chain ID: 222888 = Moca Testnet, 5151 = Moca Devnet.
NEXT_PUBLIC_PAYMENT_CHAIN_ID=222888
NEXT_PUBLIC_PAYMENT_CONTROLLER_ADDRESS=0x56ad210e36c8424d1d1cc5166b3f9fa4c03a8942
